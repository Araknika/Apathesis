script = ExtResource("1_n5d8t")
read_text = "DESPITE THE RAGGED NATURE OF THE NOTE, THE HANDWRITING IS PERFECT.
[color=E8E5C8]\"FIND THE SHARD OF [color=#A82525] APATHESIS[/color].
DESTROY [color=#700f46] IT [/color].
FREE [color=1773E3] HER [/color].
GODS SAVE YOU.\"[/color]"
quest_text = "A STRANGE NOTE HAS TOLD YOU TO FIND SOMETHING CALLED THE SHARD OF [color=#A82525] APATHESIS[/color]. IT HAD SOME CRYPTIC MENTIONS OF [color=1773E3] HER [/color]. WHAT EITHER OF THINGS THINGS MEAN REMAINS A MYSTERY..."
item_name = "TORN NOTE"
item_type = 5
item_description = "A SCRAP OF PAPER, HASTILY TORN AT THE EDGES."
pickup_text = "YOU POCKET THE NOTE"
